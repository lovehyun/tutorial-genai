# Notion API 설정
# https://www.notion.so/my-integrations 에서 Internal Integration 생성 후 토큰 입력
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 강의 교안이 위치한 Notion 상위 페이지 ID
# 페이지 URL에서 마지막 32자리 (하이픈 제거)
# 예: https://www.notion.so/My-Page-1234567890abcdef1234567890abcdef
#     → NOTION_PARENT_PAGE_ID=1234567890abcdef1234567890abcdef
NOTION_PARENT_PAGE_ID=

# Google Gemini API 설정 (삽화 이미지 생성용)
# https://aistudio.google.com/apikey 에서 API 키 생성
GOOGLE_API_KEY=
