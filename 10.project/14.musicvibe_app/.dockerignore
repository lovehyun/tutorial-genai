# ==========================================================================
# VIBE MUSIC SNS - DOCKER BUILD IGNORE RULES
# ==========================================================================

# 1. 파이썬 컴파일 캐시
__pycache__/
*.pyc
*.pyo
*.pyd

# 2. 로컬 데이터베이스 및 임시 캐시 (컨테이너 내에서 항상 클린 상태로 구동)
instance/*.db
instance/*.sqlite
instance/*.sqlite3
.sessions/

# 3. 개발 도구 및 형상 관리 설정 파일
.git/
.gitignore
.dockerignore
Dockerfile
.vscode/
.idea/

# 4. 로그 및 테스트 산출물
*.log
scratch/
walkthrough.md
implementation_plan.md
task.md
