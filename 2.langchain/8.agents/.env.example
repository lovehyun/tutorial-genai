# 8.agents 예제 실행에 필요한 키
# 사용법: 이 파일을 같은 폴더에 ".env" 로 복사한 뒤 값을 채우세요.
#         (또는 상위 공용 파일 ../.env = 2.langchain/.env 에 채워도 됩니다.
#          load_dotenv() 는 실행 폴더에서 위로 올라가며 처음 만난 .env 를 사용)

# ── 필수 ───────────────────────────────────────────────
# 모든 create_agent 예제가 ChatOpenAI(gpt-4o-mini) 를 사용
OPENAI_API_KEY=

# ── 웹 검색 (1.4_web_search_minimal.py, 1.5_web_search.py) ──
# Tavily 가 기본/권장. https://app.tavily.com 에서 무료 발급
TAVILY_API_KEY=

# 1.5 의 대안 검색 엔진 (주석 해제해서 쓸 때만 필요)
SERPER_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ── 선택: reasoning 모델 변형 (1.3_wikipedia_think.py) ──
# Anthropic claude 로 thinking 을 보려는 경우에만
ANTHROPIC_API_KEY=

# 키 불필요 도구: wikipedia, arxiv (pip 패키지만 설치하면 됨)
#   pip install wikipedia arxiv langchain-tavily
