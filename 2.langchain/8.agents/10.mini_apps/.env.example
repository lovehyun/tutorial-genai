# 10.mini_apps 실행에 필요한 키
# 사용법: 이 파일을 ".env" 로 복사해 값을 채우거나, 상위 2.langchain/.env 에 채우세요.
# (키가 없어도 각 앱은 안내 메시지/콘솔 폴백으로 동작하도록 만들어져 있음)

# ── 공통 (필수) ───────────────────────────────────────
OPENAI_API_KEY=

# ── 2.finance_bot (선택) ──────────────────────────────
# 네이버 뉴스: https://developers.naver.com 에서 검색 API 등록
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# 구글 검색(기업정보): https://serper.dev
SERPER_API_KEY=
# (환율 open.er-api.com / 주가 yfinance 는 키 불필요)

# ── 3.trading_bot — 이메일 HITL (선택, 없으면 콘솔 폴백) ──
EMAIL_USER=                 # 보내는 Gmail 주소
EMAIL_APP_PASSWORD=         # Gmail 앱 비밀번호 (2단계 인증 후 발급)
EMAIL_TO=                   # 받는 주소 (비우면 EMAIL_USER 로)

# ── 3.trading_bot — 동작 설정 (선택, 기본값 있음) ────────
APP_BASE_URL=http://localhost:5001
USD_RATE_THRESHOLD=1500     # USD/KRW 이 값 이하면 환전 승인 요청
WATCH_TICKER=AAPL           # 감시할 주식
STOCK_BUY_BELOW=150         # 이 값(USD) 이하면 매수 승인 요청
