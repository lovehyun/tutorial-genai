# 2.finance_bot 실행에 필요한 키
# 사용법: 이 파일을 ".env" 로 복사해 값을 채우거나, 상위 2.langchain/.env 에 채우세요.
# (선택 키가 없어도 해당 도구만 안내 메시지를 반환하고, 앱은 계속 동작)

# ── 필수 ──────────────────────────────────────────────
OPENAI_API_KEY=

# ── 뉴스 (get_news, 선택) ─────────────────────────────
# 네이버 검색 API: https://developers.naver.com → 애플리케이션 등록 → 검색
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 기업 정보 (get_company_info, 선택) ────────────────
# 구글 검색: https://serper.dev 에서 무료 발급
SERPER_API_KEY=

# ── 키 불필요 도구 ────────────────────────────────────
#   get_exchange_rate : open.er-api.com (무료, 키 X)
#   get_stock_price   : yfinance (키 X)  → pip install yfinance
