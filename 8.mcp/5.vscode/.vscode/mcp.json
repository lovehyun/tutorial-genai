{
  // VSCode(1.102+) 워크스페이스 MCP 설정.
  // 이 폴더(8.mcp/5.vscode)를 VSCode 로 열면 ${workspaceFolder} = 이 폴더가 되어
  // 아래 server.py 가 그대로 실행된다.
  //
  // python 이 PATH 에 없거나 venv 를 쓰면 "command" 를 venv 의 python 절대경로로 바꾸세요.
  //   예) "command": "C:\\path\\to\\.venv\\Scripts\\python.exe"
  "servers": {
    "dev-helper": {
      "type": "stdio",
      "command": "python",
      "args": ["${workspaceFolder}/server.py"]
    }
  }
}
